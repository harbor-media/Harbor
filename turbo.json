{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@harbor/web#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "../server/public/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"],
      "env": [
        "NODE_ENV",
        "DATABASE_URL",
        "HARBOR_PORT",
        "HARBOR_HOST",
        "HARBOR_BASE_URL",
        "HARBOR_SECRET",
        "HARBOR_DATA_DIRECTORY",
        "HARBOR_LOG_LEVEL",
        "HARBOR_TRUST_PROXY",
        "HARBOR_VERSION",
        "HARBOR_MIGRATIONS_DIR"
      ]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["E2E_DATABASE_URL", "CI"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": [
        "NODE_ENV",
        "DATABASE_URL",
        "HARBOR_PORT",
        "HARBOR_HOST",
        "HARBOR_BASE_URL",
        "HARBOR_SECRET",
        "HARBOR_DATA_DIRECTORY",
        "HARBOR_LOG_LEVEL",
        "HARBOR_TRUST_PROXY",
        "HARBOR_VERSION",
        "HARBOR_MIGRATIONS_DIR"
      ]
    }
  }
}
